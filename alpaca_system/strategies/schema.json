{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "交易策略定義",
  "type": "object",
  "required": ["name", "universe", "selection", "sizing", "rebalance"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "universe": {
      "type": "object",
      "required": ["source", "top_n"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string", "enum": ["nasdaq"] },
        "rank_by": { "type": "string", "enum": ["market_cap"] },
        "top_n": { "type": "integer", "minimum": 1 }
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string", "enum": ["momentum"] },
          "lookback_days": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "selection": {
      "type": "object",
      "required": ["rank_by", "top_n"],
      "additionalProperties": false,
      "properties": {
        "rank_by": { "type": "string", "enum": ["momentum", "market_cap"] },
        "order": { "type": "string", "enum": ["asc", "desc"], "default": "desc" },
        "top_n": { "type": "integer", "minimum": 1 }
      }
    },
    "sizing": {
      "type": "object",
      "required": ["method"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "enum": ["equal_weight"] },
        "weight_per_position": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "shares": { "type": "string", "enum": ["integer"] }
      }
    },
    "rebalance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schedule": {
          "type": "string",
          "enum": ["monthly_first_trading_day", "daily", "none"]
        },
        "on_new_cash": { "type": "boolean" }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "long_only": { "type": "boolean" },
        "max_positions": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
